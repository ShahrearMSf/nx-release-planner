# Copy this file to .env and fill in values for local development.
# In CI, set the same names as repo secrets / variables.

# Slack Incoming Webhook URL — required to actually post.
# Leave unset (or use `npm run dry-run`) to print the payload to stdout.
SLACK_WEBHOOK_URL=

# Base URLs used by the scrapers and the Slack message buttons.
# All have sensible defaults baked in — override only if a URL changes.
FREE_PLUGIN_URL=https://wordpress.org/plugins/notificationx/
PRO_CHANGELOG_URL=https://notificationx.com/changelog/
PRO_SITE_URL=https://notificationx.com/
SUPPORT_FORUM_URL=https://wordpress.org/support/plugin/notificationx/

# Optional: override "today" for testing. ISO date, e.g. 2026-05-20.
RUN_DATE=

# Optional: 1 to print payload without posting.
DRY_RUN=
